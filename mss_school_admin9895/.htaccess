Options -Indexes
RewriteEngine On

# 1. If real file or folder exists → serve normally (PHP, images, API)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. IMPORTANT: ignore API folder (PHP backend)
RewriteRule ^api/ - [L]

# 3. React fallback
RewriteRule ^ index.html [L]